{
	"name": "arri-camera-control",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:mock": "vite dev --mode development",
		"dev:prod": "vite dev --mode production",
		"build": "vite build",
		"build:dev": "vite build --mode development",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"build:mobile": "node scripts/build-mobile.js",
		"build:ios": "node scripts/build-ios.js",
		"build:android": "node scripts/build-android.js",
		"test:mobile": "node scripts/test-mobile.js",
		"deploy:mobile": "node scripts/deploy-mobile.js",
		"deploy:ios": "node scripts/deploy-mobile.js --ios",
		"deploy:android": "node scripts/deploy-mobile.js --android",
		"deploy:all": "node scripts/deploy-mobile.js --all",
		"mobile:ios": "npm run build:mobile && npx cap open ios",
		"mobile:android": "npm run build:mobile && npx cap open android",
		"mobile:run:ios": "npm run build:mobile && npx cap run ios",
		"mobile:run:android": "npm run build:mobile && npx cap run android",
		"mobile:sync": "npx cap sync"
	},
	"dependencies": {
		"@capacitor/android": "^7.4.2",
		"@capacitor/cli": "^7.4.2",
		"@capacitor/core": "^7.4.2",
		"@capacitor/filesystem": "^7.1.4",
		"@capacitor/haptics": "^7.0.2",
		"@capacitor/ios": "^7.4.2",
		"@capacitor/network": "^7.0.2",
		"@capacitor/splash-screen": "^7.0.2",
		"@capacitor/status-bar": "^7.0.2",
		"@tailwindcss/typography": "^0.5.10",
		"socket.io-client": "^4.7.4"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@testing-library/jest-dom": "^6.1.5",
		"@testing-library/svelte": "^4.0.5",
		"@vitest/coverage-v8": "^1.0.4",
		"@vitest/ui": "^1.0.4",
		"autoprefixer": "^10.4.16",
		"jsdom": "^23.0.1",
		"playwright": "^1.40.1",
		"postcss": "^8.4.32",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.3.6",
		"typescript": "^5.0.0",
		"vite": "^7.0.4",
		"vitest": "^1.0.4"
	}
}
