# ARRI Camera Control Backend Configuration

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Logging Configuration
LOG_LEVEL=info

# Authentication Configuration (optional)
# VALID_TOKENS=demo-token,another-token

# CAP Protocol Configuration
CAP_CONNECTION_TIMEOUT=30000
CAP_MESSAGE_TIMEOUT=5000
CAP_MAX_RETRIES=3
CAP_RETRY_DELAY=2000

# WebSocket Configuration
WS_MAX_CONNECTIONS=100
WS_CLEANUP_INTERVAL=30000
WS_METRICS_INTERVAL=60000